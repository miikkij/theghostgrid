# Server
PORT=7620
HOST=0.0.0.0
LOG_LEVEL=info

# Burst cycle timing
BURST_CYCLE_MS=1000
SYNC_ALPHA_OFFSET_MS=0
SYNC_BETA_OFFSET_MS=215
BURST_WINDOW_MS=50

# Protocol
MASTER_SECRET=

# Radio interfaces (set RADIO_ENABLED=true when USB adapters are connected)
RADIO_ENABLED=false
RADIO_DRONE_IFACE=wlan1
RADIO_GROUND_1_IFACE=wlan2
RADIO_GROUND_2_IFACE=wlan3

# ConfidentialMind AI endpoint
CM_ENDPOINT=https://api.confidentialmind.com/v1/chat
CM_API_KEY=
CM_MODEL=llama-3-70b

# Demo parameters
NUM_SIMULATED_DECOYS=47
NUM_SIMULATED_SOLDIERS=0
ENABLE_HAPTIC=true
ENABLE_AUDIO_FEEDBACK=false
